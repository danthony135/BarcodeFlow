# Pervasive SQL / RETAILvantage ODBC Connection
ODBC_DSN=RETAILvantage
# Or use a full connection string:
# ODBC_CONNECTION_STRING=Driver={Pervasive ODBC Interface};ServerName=localhost;DBQ=RETAILVANTAGE;

# BarcodeFlow API
BARCODEFLOW_URL=https://barcodeflow.up.railway.app
BARCODEFLOW_API_KEY=your-api-key-here

# Sync intervals (seconds)
SYNC_PULL_INTERVAL=300
SYNC_PUSH_INTERVAL=120

# Printer
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# Logging
LOG_LEVEL=INFO
